# =============================================================================
# AI Hiring & Assessment Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/hiring-platform
# Or MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/hiring-platform

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=5002
NODE_ENV=development

FRONTEND_URL=http://localhost:3000,http://localhost:3001
# Google Gemini API Configuration
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_LARGE_MODEL=gemini-2.5-pro

# -----------------------------------------------------------------------------
# Judge0 Code Execution (Required for programming tests)
# -----------------------------------------------------------------------------
# Option 1: RapidAPI (Recommended for quick setup)
# Get your key from: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your-rapidapi-key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Option 2: Self-hosted Judge0
# JUDGE0_API_URL=http://localhost:2358
# JUDGE0_API_KEY=

# -----------------------------------------------------------------------------
# Email Configuration (Optional in development)
# -----------------------------------------------------------------------------
# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email sender
EMAIL_FROM=noreply@yourcompany.com
